####  Elastic Deployment for Relevance Studio  #################################
# 
# Configure your connection to Elasticsearch.
# The Elasticsearch Relevance Studio indices (esrs-*) will be stored here.
#
# Endpoint:
#   - Choose either ELASTIC_CLOUD_ID or ELASTICSEARCH_URL.
#   - ELASTIC_CLOUD_ID takes precedence if you also configure ELASTICSEARCH_URL.
# 
ELASTIC_CLOUD_ID=
ELASTICSEARCH_URL=

# Authentication:
#   - Choose either ELASTICSEARCH_API_KEY or ELASTICSEARCH_USERNAME & ELASTICSEARCH_PASSWORD.
#   - If both are configured, startup fails with an error.
# 
# When AUTH_ENABLED=true, these credentials are used by the worker process as a
# service account. See docs for the full studio deployment role configuration.
# 
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=


####  (OPTIONAL) Elastic Deployment for Source Content  ########################
#
# If you want to store the Elasticsearch Relevance Studio indices (esrs-*) on
# a separate deployment from the content that you will judge and evaluate,
# you can configure a separate connection to the content deployment below.
# If you leave these blank, the configurations above will be used for both.
# 
# Endpoint:
#   - Choose either CONTENT_ELASTIC_CLOUD_ID or CONTENT_ELASTICSEARCH_URL.
#   - CONTENT_ELASTIC_CLOUD_ID takes precedence if you also configure CONTENT_ELASTICSEARCH_URL.
# 
# CONTENT_ELASTIC_CLOUD_ID=
# CONTENT_ELASTICSEARCH_URL=

# Authentication:
#   - Choose either CONTENT_ELASTICSEARCH_API_KEY or CONTENT_ELASTICSEARCH_USERNAME & CONTENT_ELASTICSEARCH_PASSWORD.
#   - If both are configured, startup fails with an error.
# 
# CONTENT_ELASTICSEARCH_API_KEY=
# CONTENT_ELASTICSEARCH_USERNAME=
# CONTENT_ELASTICSEARCH_PASSWORD=


####  (OPTIONAL) TLS for Server and MCP  ########################################
#
# Native TLS is enabled by default. When TLS_ENABLED is true, you must provide
# valid PEM certificate and key file paths. Set TLS_ENABLED=false to run over
# HTTP (e.g. behind a reverse proxy that terminates TLS).
#
# TLS_ENABLED: Set to "false" to serve over HTTP. Default: true
#
# TLS_CERT_FILE: Path to PEM certificate file. Required when TLS_ENABLED is true.
#
# TLS_KEY_FILE: Path to PEM private key file. Required when TLS_ENABLED is true.
#
# Generating a self-signed certificate:
#
#   Run the following command (same on macOS and Linux) to generate a cert and
#   key valid for localhost:
#
#     mkdir -p .certs
#     openssl req -x509 -newkey rsa:4096 -sha256 -days 365 -nodes \
#       -keyout .certs/key.pem -out .certs/cert.pem \
#       -subj "/CN=localhost" \
#       -addext "subjectAltName=IP:127.0.0.1,DNS:localhost"
#
#   Then set:
#     TLS_CERT_FILE=.certs/cert.pem
#     TLS_KEY_FILE=.certs/key.pem
#
# Trusting the self-signed certificate (to avoid browser/client warnings):
#
#   macOS:
#     sudo security add-trusted-cert -d -r trustRoot \
#       -k /Library/Keychains/System.keychain .certs/cert.pem
#
#   Linux (Debian/Ubuntu):
#     sudo cp .certs/cert.pem /usr/local/share/ca-certificates/relevance-studio.crt
#     sudo update-ca-certificates
#
#   Linux (RHEL/Fedora/CentOS):
#     sudo cp .certs/cert.pem /etc/pki/ca-trust/source/anchors/relevance-studio.pem
#     sudo update-ca-trust
#
# TLS_ENABLED=true
# TLS_CERT_FILE=
# TLS_KEY_FILE=


####  Authentication  ##########################################################
#
# When AUTH_ENABLED is true (default), API routes require login. Users authenticate
# with Elasticsearch credentials (username/password or API key) via POST /api/auth/login.
# A session cookie (JWT) is issued for subsequent requests.
#
# AUTH_ENABLED: Set to "false" if the studio deployment has no authentication.
#   Default: true
#
# AUTH_JWT_SECRET: Secret for signing session JWTs. Required when AUTH_ENABLED is true.
#   Generate a strong random value (e.g. openssl rand -hex 32).
#
# AUTH_SESSION_EXPIRY: Session expiry (JWT + cookie max-age) (e.g. "24h", "7d", "30m").
#   Default: 24h
#
# AUTH_ENABLED=true
# AUTH_JWT_SECRET=
# AUTH_SESSION_EXPIRY=24h


####  (OPTIONAL) OpenTelemetry Instrumentation  ################################
# 
# You can instrument Elaasticsearch Relevance Studio with OpenTelemetry by
# setting the value of OTEL_EXPORTER_OTLP_ENDPOINT. You can set this to the
# OTLP receiver endpoint of an OpenTelemetry Collector [1], the endpoint of an
# Elastic APM Server [2], or the Elastic Cloud Managed OTLP Endpoint [3]:
# 
#   [1] https://opentelemetry.io/docs/collector/
#   [2] https://www.elastic.co/docs/solutions/observability/apm/use-opentelemetry-with-apm
#   [3] https://www.elastic.co/docs/reference/opentelemetry/motlp
# 
# Elastic Cloud will require authentication. You can configure this in the
# headers using an Elasticsearch API Key. Example:
# 
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=ApiKey BASE64_ENCODED_API_KEY
# 
# For all other OTEL environment variables, refer to the OpenTelemetry docs:
#
#   https://opentelemetry.io/docs/specs/otel/configuration/sdk-environment-variables/
# 
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_RESOURCE_ATTRIBUTES=